{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://datas/schemas/time_system.schema.json",
  "title": "TimeSystemConfig",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "time", "calendar", "speed_presets", "speed_range"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "时间系统配置版本。变更字段语义时递增。",
      "minimum": 1,
      "default": 1
    },
    "time": {
      "type": "object",
      "additionalProperties": false,
      "required": ["real_seconds_per_game_hour"],
      "properties": {
        "real_seconds_per_game_hour": {
          "type": "number",
          "description": "现实时间换算倍率：多少秒现实时间等于 1 游戏小时。",
          "minimum": 0.01,
          "default": 1.0
        }
      }
    },
    "calendar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hours_per_day", "days_per_week", "days_per_month", "months_per_year"],
      "properties": {
        "hours_per_day": {
          "type": "integer",
          "description": "每游戏天包含的小时数。",
          "minimum": 1,
          "default": 24
        },
        "days_per_week": {
          "type": "integer",
          "description": "每游戏周包含的天数。",
          "minimum": 1,
          "default": 7
        },
        "days_per_month": {
          "type": "integer",
          "description": "每游戏月包含的天数。",
          "minimum": 1,
          "default": 28
        },
        "months_per_year": {
          "type": "integer",
          "description": "每游戏年包含的月数。",
          "minimum": 1,
          "default": 12
        }
      }
    },
    "speed_presets": {
      "type": "object",
      "description": "时间面板上的标准倍速按钮配置。",
      "additionalProperties": false,
      "required": ["x1", "x2", "x6", "x96"],
      "properties": {
        "x1": { "type": "number", "minimum": 0.1, "default": 1.0, "description": "1x 按钮对应速度倍率。" },
        "x2": { "type": "number", "minimum": 0.1, "default": 2.0, "description": "2x 按钮对应速度倍率。" },
        "x6": { "type": "number", "minimum": 0.1, "default": 6.0, "description": "6x 按钮对应速度倍率。" },
        "x96": { "type": "number", "minimum": 0.1, "default": 96.0, "description": "96x 按钮对应速度倍率。" }
      }
    },
    "speed_range": {
      "type": "object",
      "description": "允许设置的速度倍率区间（用于 clamp）。",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0.1,
          "default": 1.0,
          "description": "允许的最小速度倍率。"
        },
        "max": {
          "type": "number",
          "minimum": 0.1,
          "default": 96.0,
          "description": "允许的最大速度倍率。"
        }
      }
    }
  }
}
