{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://datas/schemas/room_size_config.schema.json",
  "title": "RoomSizeConfig",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "sizes"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "房间尺寸配置版本。变更字段语义时递增。",
      "minimum": 1,
      "default": 1
    },
    "sizes": {
      "type": "object",
      "description": "尺寸类型 ID（base/tall/small/small_tall/long）到 volum 与单位的映射。",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["volume", "units"],
        "properties": {
          "volume": {
            "type": "array",
            "description": "3D 体积 [x, y, z]，单位 0.5m 格子。",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "units": {
            "type": "integer",
            "description": "清理/建设/产出/住房使用的房间单位数。",
            "minimum": 1
          }
        }
      }
    }
  }
}
