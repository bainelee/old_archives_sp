[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/ui/exploration_region_info_panel.gd" id="1_script"]
[ext_resource type="Theme" path="res://assets/ui/detail_panel_theme.tres" id="2_theme"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_panel"]
bg_color = Color(0.92, 0.92, 0.93, 1)
border_width_left = 1
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
border_color = Color(0.08, 0.08, 0.08, 0.85)

[node name="ExplorationRegionInfoPanel" type="PanelContainer"]
clip_contents = false
custom_minimum_size = Vector2(320, 180)
theme = ExtResource("2_theme")
theme_override_styles/panel = SubResource("StyleBoxFlat_panel")
script = ExtResource("1_script")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="TitleRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="TitleLabel" type="Label" parent="Margin/VBox/TitleRow"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_colors/font_color = Color(0.06, 0.06, 0.08, 1)
theme_override_font_sizes/font_size = 18
text = "地区"

[node name="BtnClose" type="Button" parent="Margin/VBox/TitleRow"]
custom_minimum_size = Vector2(72, 32)
layout_mode = 2
text = "关闭"

[node name="StatusLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.12, 0.12, 0.14, 1)
theme_override_font_sizes/font_size = 14
text = "状态：—"
autowrap_mode = 2

[node name="DurationLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.12, 0.12, 0.14, 1)
theme_override_font_sizes/font_size = 13
text = "预计探索时间：—"
autowrap_mode = 2

[node name="InvestLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.12, 0.12, 0.14, 1)
theme_override_font_sizes/font_size = 13
text = "调查员：—"
autowrap_mode = 2

[node name="RewardLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.12, 0.12, 0.14, 1)
theme_override_font_sizes/font_size = 13
text = "可能获得：—"
autowrap_mode = 2

[node name="BtnExplore" type="Button" parent="Margin/VBox"]
custom_minimum_size = Vector2(0, 36)
layout_mode = 2
mouse_filter = 0
text = "开始探索"

[node name="InvestigationSitesLabel" type="Label" parent="Margin/VBox"]
visible = false
layout_mode = 2
theme_override_colors/font_color = Color(0.1, 0.1, 0.12, 1)
theme_override_font_sizes/font_size = 14
text = "调查点"

[node name="InvestigationSitesBox" type="VBoxContainer" parent="Margin/VBox"]
visible = false
layout_mode = 2
theme_override_constants/separation = 6
