{
  "flowId": "base_validation_slot0_phase1",
  "name": "Base validation phase1: new game clean/build save",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 20,
  "env": {
    "CLEAN_ROOM_ID": "room_01",
    "CLEAN_ROOM_TEST_ID": "room_node_room_01",
    "BUILD_ROOM_ID": "room_01",
    "BUILD_ROOM_TEST_ID": "room_node_room_01"
  },
  "steps": [
    {
      "id": "prepare_new_game",
      "action": "runSubflow",
      "file": "common/new_game_enter_world.json"
    },
    {
      "id": "start_cleanup_mode",
      "action": "click",
      "target": { "testId": "btn_cleanup" }
    },
    {
      "id": "select_cleanup_room",
      "action": "click",
      "target": { "testId": "${CLEAN_ROOM_TEST_ID}" }
    },
    {
      "id": "confirm_cleanup",
      "action": "click",
      "target": { "testId": "cleanup_confirm_button" }
    },
    {
      "id": "wait_clean_done",
      "action": "wait",
      "until": {
        "stateEquals": { "key": "room_clean_status", "value": "cleaned", "roomId": "${CLEAN_ROOM_ID}" }
      },
      "timeoutMs": 7000
    },
    {
      "id": "start_build_mode",
      "action": "click",
      "target": { "testId": "btn_build" }
    },
    {
      "id": "wait_research_zone_visible",
      "action": "wait",
      "until": {
        "nodeVisible": { "testId": "construction_zone_1" }
      },
      "timeoutMs": 5000
    },
    {
      "id": "select_build_zone",
      "action": "click",
      "target": { "testId": "construction_zone_1" }
    },
    {
      "id": "select_build_room",
      "action": "click",
      "target": { "testId": "${BUILD_ROOM_TEST_ID}" }
    },
    {
      "id": "wait_build_confirm_visible",
      "action": "wait",
      "until": {
        "nodeVisible": { "testId": "construction_confirm_button" }
      },
      "timeoutMs": 5000
    },
    {
      "id": "confirm_build",
      "action": "click",
      "target": { "testId": "construction_confirm_button" }
    },
    {
      "id": "wait_build_done",
      "action": "wait",
      "until": {
        "stateEquals": { "key": "build_status", "value": "built", "roomId": "${BUILD_ROOM_ID}" }
      },
      "timeoutMs": 10000
    },
    {
      "id": "set_game_speed_x1_before_save",
      "action": "setGameTimeSpeed",
      "speed": 1.0
    },
    {
      "id": "save_game_slot0",
      "action": "saveGame"
    }
  ]
}
