{
  "flowId": "smoke_continue_exploration_toggle",
  "name": "烟测：继续游戏 → 打开探索界面 → 关闭 → 结束后由 Runner 退出进程",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 25,
  "driverReadyTimeoutSec": 25,
  "driverNoActivityTimeoutSec": 8,
  "steps": [
    { "id": "sleep_boot", "action": "sleep", "ms": 800 },
    { "id": "click_continue", "action": "click", "target": { "testId": "btn_continue" } },
    {
      "id": "wait_ingame",
      "action": "wait",
      "until": { "scene": "game_main" },
      "minWaitMs": 200,
      "timeoutMs": 15000
    },
    {
      "id": "click_open_exploration_map",
      "action": "click",
      "target": { "testId": "btn_center" }
    },
    {
      "id": "verify_exploration_overlay_visible",
      "action": "check",
      "kind": "logic_state",
      "expect": { "exploration_overlay_visible": true },
      "timeoutMs": 5000
    },
    {
      "id": "click_close_exploration",
      "action": "click",
      "target": { "testId": "btn_exploration_close" }
    },
    {
      "id": "verify_exploration_overlay_hidden",
      "action": "check",
      "kind": "logic_state",
      "expect": { "exploration_overlay_visible": false },
      "timeoutMs": 5000
    }
  ]
}
