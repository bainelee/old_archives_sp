{
  "flowId": "room_hover_click_projection_matrix_zoom_slot0",
  "name": "正厅聚焦后房间投影矩阵（缩放扰动）",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 20,
  "driverReadyTimeoutSec": 20,
  "driverNoActivityTimeoutSec": 5,
  "env": {
    "HALL_ROOM_TEST_ID": "room_node_room_00"
  },
  "steps": [
    {
      "id": "prepare_new_game",
      "action": "runSubflow",
      "file": "../../../fragments/common/new_game_enter_world.json"
    },
    {
      "id": "focus_hall_room",
      "action": "click",
      "target": { "testId": "${HALL_ROOM_TEST_ID}" }
    },
    {
      "id": "wait_hall_selected",
      "action": "wait",
      "until": { "stateEquals": { "key": "selected_room_id", "value": "room_00" } },
      "timeoutMs": 3000
    },
    {
      "id": "zoom_in_for_projection_matrix",
      "action": "wheelZoom",
      "direction": "in",
      "steps": 3
    },
    {
      "id": "wait_after_zoom_in",
      "action": "sleep",
      "ms": 400
    },
    {
      "id": "verify_projection_matrix_after_zoom_in",
      "action": "check",
      "kind": "room_projection_hover_click_matrix",
      "expect": {
        "minRooms": 0,
        "maxRooms": 12,
        "skipSelected": true,
        "skipUiCovered": true,
        "strict": true,
        "failOnNoRawHit": true
      },
      "timeoutMs": 10000
    },
    {
      "id": "zoom_out_for_projection_matrix",
      "action": "wheelZoom",
      "direction": "out",
      "steps": 4
    },
    {
      "id": "wait_after_zoom_out",
      "action": "sleep",
      "ms": 400
    },
    {
      "id": "verify_projection_matrix_after_zoom_out",
      "action": "check",
      "kind": "room_projection_hover_click_matrix",
      "expect": {
        "minRooms": 0,
        "maxRooms": 12,
        "skipSelected": true,
        "skipUiCovered": true,
        "strict": true,
        "failOnNoRawHit": true
      },
      "timeoutMs": 10000
    }
  ]
}
