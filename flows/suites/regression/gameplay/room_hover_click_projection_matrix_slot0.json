{
  "flowId": "room_hover_click_projection_matrix_slot0",
  "name": "正厅聚焦后房间屏幕投影悬停点击矩阵",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 20,
  "driverReadyTimeoutSec": 20,
  "driverNoActivityTimeoutSec": 5,
  "env": {
    "HALL_ROOM_TEST_ID": "room_node_room_00",
    "ROOM_A_TEST_ID": "room_node_room_03",
    "ROOM_A_ID": "room_03"
  },
  "steps": [
    {
      "id": "prepare_new_game",
      "action": "runSubflow",
      "file": "../../../fragments/common/new_game_enter_world.json"
    },
    {
      "id": "focus_hall_room",
      "action": "click",
      "target": { "testId": "${HALL_ROOM_TEST_ID}" }
    },
    {
      "id": "wait_hall_selected",
      "action": "wait",
      "until": { "stateEquals": { "key": "selected_room_id", "value": "room_00" } },
      "timeoutMs": 3000
    },
    {
      "id": "verify_projection_hover_click_matrix",
      "action": "check",
      "kind": "room_projection_hover_click_matrix",
      "expect": {
        "minRooms": 0,
        "maxRooms": 8,
        "skipSelected": true,
        "skipUiCovered": true
      },
      "timeoutMs": 10000
    }
  ]
}
