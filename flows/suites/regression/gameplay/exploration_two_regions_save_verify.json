{
  "flowId": "exploration_two_regions_save_verify",
  "name": "探索：完成两区并保存，校验存档 exploration 块与读档恢复",
  "system": "exploration",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 45,
  "driverReadyTimeoutSec": 25,
  "driverNoActivityTimeoutSec": 8,
  "reloadProjectBeforeRun": false,
  "steps": [
    {
      "id": "new_game_slot0",
      "action": "runSubflow",
      "file": "../../../fragments/common/new_game_enter_world.json"
    },
    {
      "id": "set_speed_1",
      "action": "setGameTimeSpeed",
      "speed": 1.0
    },
    {
      "id": "explore_white_cliff",
      "action": "exploreRegion",
      "regionId": "white_cliff"
    },
    {
      "id": "tick_finish_white_cliff",
      "action": "advanceGameHours",
      "hours": 30.0
    },
    {
      "id": "explore_durkin",
      "action": "exploreRegion",
      "regionId": "durkin_mine"
    },
    {
      "id": "tick_finish_durkin",
      "action": "advanceGameHours",
      "hours": 30.0
    },
    {
      "id": "assert_memory_explored",
      "action": "check",
      "kind": "logic_state",
      "expect": {
        "exploration_explored_ids": ["durkin_mine", "old_archives", "white_cliff"]
      },
      "timeoutMs": 5000
    },
    {
      "id": "save_slot",
      "action": "saveGame"
    },
    {
      "id": "verify_json_exploration",
      "action": "verifySaveSlotExploration",
      "slot": 0,
      "mustContainExplored": ["old_archives", "white_cliff", "durkin_mine"]
    },
    {
      "id": "reload_game_main_slot0",
      "action": "loadGameMainFromSlot",
      "slot": 0
    },
    {
      "id": "wait_ingame_reload",
      "action": "wait",
      "until": { "scene": "game_main" },
      "minWaitMs": 300,
      "timeoutMs": 8000
    },
    {
      "id": "assert_reload_explored",
      "action": "check",
      "kind": "logic_state",
      "expect": {
        "exploration_explored_ids": ["durkin_mine", "old_archives", "white_cliff"]
      },
      "timeoutMs": 8000
    }
  ]
}
