{
  "flowId": "exploration_validation_l3_overlay_input_block",
  "name": "Exploration L3: overlay blocks world click-through",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 20,
  "driverReadyTimeoutSec": 20,
  "driverNoActivityTimeoutSec": 5,
  "steps": [
    {
      "id": "sleep_boot",
      "action": "sleep",
      "ms": 500
    },
    {
      "id": "click_continue",
      "action": "click",
      "target": { "testId": "btn_continue" }
    },
    {
      "id": "wait_ingame",
      "action": "wait",
      "until": { "scene": "game_main" },
      "minWaitMs": 300,
      "timeoutMs": 3000
    },
    {
      "id": "set_game_speed_x1_stable",
      "action": "setGameTimeSpeed",
      "speed": 1.0
    },
    {
      "id": "open_exploration_overlay",
      "action": "click",
      "target": { "testId": "btn_center" }
    },
    {
      "id": "check_overlay_opened",
      "action": "check",
      "kind": "logic_state",
      "expect": { "exploration_overlay_visible": true },
      "timeoutMs": 3000
    },
    {
      "id": "click_overlay_backdrop_area",
      "action": "click",
      "target": { "nodePath": "/root/GameMain/InteractiveUiRoot/ExplorationMapOverlay/OverlayRoot/MapArea/MapStack" }
    },
    {
      "id": "check_overlay_blocks_world_clickthrough",
      "action": "check",
      "kind": "logic_state",
      "expect": {
        "exploration_overlay_visible": true
      },
      "timeoutMs": 3000
    },
    {
      "id": "check_overlay_blocks_wheel_zoom",
      "action": "check",
      "kind": "camera_unchanged_after_wheel",
      "expect": {
        "steps": 8,
        "direction": "up",
        "requireExplorationOverlay": true
      }
    },
    {
      "id": "shot_overlay_block_result",
      "action": "screenshot",
      "name": "flow_exploration_l3_overlay_block"
    }
  ]
}
