{
  "flowId": "info_currency_week_slot0_phase1",
  "name": "信息货币周结：新游戏存档0，2倍速，推进游戏内一周，校验信息增量后存盘并回主菜单",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 30,
  "driverReadyTimeoutSec": 20,
  "driverNoActivityTimeoutSec": 8,
  "steps": [
    {
      "id": "prepare_new_game",
      "action": "runSubflow",
      "file": "../../../fragments/common/new_game_enter_world.json"
    },
    {
      "id": "wait_initial_info_amount_ready",
      "action": "wait",
      "until": {
        "stateEquals": { "key": "info_amount", "value": 500 }
      },
      "minWaitMs": 200,
      "timeoutMs": 20000
    },
    {
      "id": "set_game_time_speed_x2",
      "action": "setGameTimeSpeed",
      "speed": 2.0
    },
    {
      "id": "verify_game_speed_x2",
      "action": "check",
      "kind": "logic_state",
      "expect": { "game_speed_multiplier": 2.0 },
      "timeoutMs": 3000
    },
    {
      "id": "advance_game_hours_one_week",
      "action": "advanceGameHours",
      "hours": 168.0
    },
    {
      "id": "verify_info_currency_week_design",
      "action": "check",
      "kind": "info_currency_week_design",
      "expect": {
        "baseline_info": 500,
        "days": 7,
        "min_game_total_hours": 168.0,
        "require_speed_multiplier_2": true,
        "researcher_count_cap": 10
      },
      "timeoutMs": 1000
    },
    {
      "id": "set_game_speed_x1_before_save",
      "action": "setGameTimeSpeed",
      "speed": 1.0
    },
    {
      "id": "save_game_slot0",
      "action": "saveGame"
    },
    {
      "id": "return_to_start_menu_after_save",
      "action": "changeScene",
      "path": "res://scenes/ui/start_menu.tscn"
    }
  ]
}
