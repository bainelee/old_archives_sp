    { "id": "snapshot_room_d_built", "action": "getState", "keys": ["resources", "game_total_hours"], "roomId": "${ROOM_D_ID}" },
    { "id": "start_cleanup_mode_room_e", "action": "click", "target": { "testId": "btn_cleanup" } },
    { "id": "select_cleanup_room_e", "action": "click", "target": { "testId": "${ROOM_E_TEST_ID}" } },
    { "id": "confirm_cleanup_room_e", "action": "click", "target": { "testId": "cleanup_confirm_button" } },
    {
