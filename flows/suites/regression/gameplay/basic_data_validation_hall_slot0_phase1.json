    { "id": "snapshot_room_e_cleaned", "action": "getState", "keys": ["resources", "game_total_hours"], "roomId": "${ROOM_E_ID}" },
    { "id": "start_build_mode_room_e", "action": "click", "target": { "testId": "btn_build" } },
    {
