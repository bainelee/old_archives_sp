    {
      "id": "wait_clean_done_room_c",
      "action": "wait",
      "until": { "stateEquals": { "key": "room_clean_status", "value": "cleaned", "roomId": "${ROOM_C_ID}" } },
      "timeoutMs": 7000
    },
    { "id": "snapshot_room_c_cleaned", "action": "getState", "keys": ["resources", "game_total_hours"], "roomId": "${ROOM_C_ID}" },
    { "id": "start_build_mode_room_c", "action": "click", "target": { "testId": "btn_build" } },
    {
      "id": "wait_research_zone_visible_room_c",
