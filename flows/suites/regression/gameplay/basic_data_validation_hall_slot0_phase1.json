    { "id": "confirm_build_room_e", "action": "click", "target": { "testId": "construction_confirm_button" } },
    {
      "id": "wait_build_done_room_e",
      "action": "wait",
      "until": { "stateEquals": { "key": "build_status", "value": "built", "roomId": "${ROOM_E_ID}" } },
      "timeoutMs": 10000
    },
    { "id": "snapshot_r2", "action": "getState", "keys": ["resources", "game_total_hours"], "roomId": "${ROOM_E_ID}" },
    { "id": "pause_before_save_window", "action": "setGlobalPause", "paused": true },
    {
      "id": "snapshot_pre_save_risk",
      "action": "getState",
      "keys": ["resources", "game_total_hours", "settlement_clock", "resource_ledger"],
      "roomId": "${ROOM_E_ID}"
    },
    { "id": "set_game_speed_x1_before_save", "action": "setGameTimeSpeed", "speed": 1.0 },
    { "id": "save_game_slot0", "action": "saveGame" },
    { "id": "snapshot_r2_saved", "action": "getState", "keys": ["resources", "game_total_hours"], "roomId": "${ROOM_E_ID}" },
    {
      "id": "snapshot_post_save_risk",
      "action": "getState",
      "keys": ["resources", "game_total_hours", "settlement_clock", "resource_ledger"],
      "roomId": "${ROOM_E_ID}"
    },
    { "id": "resume_after_save_window", "action": "setGlobalPause", "paused": false }
  ]
