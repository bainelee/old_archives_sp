    { "id": "select_cleanup_room_d", "action": "click", "target": { "testId": "${ROOM_D_TEST_ID}" } },
    { "id": "confirm_cleanup_room_d", "action": "click", "target": { "testId": "cleanup_confirm_button" } },
    {
