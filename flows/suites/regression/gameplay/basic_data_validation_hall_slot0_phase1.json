    { "id": "select_build_zone_room_d", "action": "click", "target": { "testId": "construction_zone_1" } },
    { "id": "select_build_room_d", "action": "click", "target": { "testId": "${ROOM_D_TEST_ID}" } },
    {
      "id": "wait_build_confirm_visible_room_d",
