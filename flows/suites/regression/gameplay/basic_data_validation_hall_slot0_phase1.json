    },
    { "id": "select_build_zone_room_e", "action": "click", "target": { "testId": "construction_zone_1" } },
    { "id": "select_build_room_e", "action": "click", "target": { "testId": "${ROOM_E_TEST_ID}" } },
    {
      "id": "wait_build_confirm_visible_room_e",
      "action": "wait",
      "until": { "nodeVisible": { "testId": "construction_confirm_button" } },
