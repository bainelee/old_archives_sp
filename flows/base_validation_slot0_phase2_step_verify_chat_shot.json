{
  "flowId": "base_validation_slot0_phase2_step_verify_chat_shot",
  "name": "Base validation phase2 with step verify and screenshots",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 20,
  "driverReadyTimeoutSec": 20,
  "driverNoActivityTimeoutSec": 5,
  "stepPreparePauseMs": 0,
  "stepVerifyPauseMs": 0,
  "screenshotPrefix": "phase2_verify_",
  "env": {
    "ROOM_ID": "room_01"
  },
  "steps": [
    { "id": "sleep_boot", "action": "sleep", "ms": 500 },
    { "id": "click_continue", "action": "click", "target": { "testId": "btn_continue" } },
    {
      "id": "wait_ingame",
      "action": "wait",
      "until": { "scene": "game_main" },
      "minWaitMs": 200,
      "timeoutMs": 2000
    },
    { "id": "shot_ingame", "action": "screenshot", "name": "phase2_ingame" },
    { "id": "set_game_speed_x1_stable", "action": "setGameTimeSpeed", "speed": 1.0 },
    {
      "id": "verify_room_cleaned",
      "action": "check",
      "kind": "logic_state",
      "roomId": "${ROOM_ID}",
      "expect": { "room_clean_status": "cleaned" },
      "timeoutMs": 5000
    },
    { "id": "shot_cleaned", "action": "screenshot", "name": "phase2_cleaned" },
    {
      "id": "verify_room_built",
      "action": "check",
      "kind": "logic_state",
      "roomId": "${ROOM_ID}",
      "expect": { "build_status": "built" },
      "timeoutMs": 5000
    },
    { "id": "shot_built", "action": "screenshot", "name": "phase2_built" }
  ]
}
