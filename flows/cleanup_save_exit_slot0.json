{
  "flowId": "cleanup_save_exit_slot0",
  "name": "New game cleanup then save and exit",
  "system": "gameplay",
  "profile": "regression",
  "mode": "local",
  "scene": "res://scenes/ui/start_menu.tscn",
  "flowStepTimeoutSec": 20,
  "driverReadyTimeoutSec": 20,
  "driverNoActivityTimeoutSec": 5,
  "env": {
    "CLEAN_ROOM_ID": "room_01",
    "CLEAN_ROOM_TEST_ID": "room_node_room_01"
  },
  "steps": [
    {
      "id": "prepare_new_game",
      "action": "runSubflow",
      "file": "common/new_game_enter_world.json"
    },
    {
      "id": "start_cleanup_mode",
      "action": "click",
      "target": { "testId": "btn_cleanup" }
    },
    {
      "id": "select_cleanup_room",
      "action": "click",
      "target": { "testId": "${CLEAN_ROOM_TEST_ID}" }
    },
    {
      "id": "confirm_cleanup",
      "action": "click",
      "target": { "testId": "cleanup_confirm_button" }
    },
    {
      "id": "wait_clean_done",
      "action": "wait",
      "until": {
        "stateEquals": { "key": "room_clean_status", "value": "cleaned", "roomId": "${CLEAN_ROOM_ID}" }
      },
      "timeoutMs": 60000,
      "timeoutSec": 120
    },
    {
      "id": "save_current_slot",
      "action": "saveGame"
    }
  ]
}
