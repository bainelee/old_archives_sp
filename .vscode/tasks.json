{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Godot: Editor (tee to .godot/terminal_godot.log)",
      "type": "shell",
      "command": "& '${config:godotTools.editorPath.godot4}' --path '${workspaceFolder}' --editor 2>&1 | Tee-Object -FilePath '${workspaceFolder}\\.godot\\terminal_godot.log' -Append",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Test Runner: OnlyPreflight",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File \"${workspaceFolder}/tools/game-test-runner/install/run-preflight.ps1\"",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Test Runner: Fast Gate",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File \"${workspaceFolder}/tools/game-test-runner/scripts/run_acceptance_ci.ps1\" -ProjectRoot \"${workspaceFolder}\" -Fast",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Test Runner: MCP Update Check",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File \"${workspaceFolder}/tools/game-test-runner/install/install-mcp.ps1\" -ProjectRoot \"${workspaceFolder}\" -CheckUpdateOnly",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
